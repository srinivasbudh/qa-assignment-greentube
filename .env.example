API_BASE_URL=https://petstore.swagger.io/v2
API_ACCEPT_HEADER=application/json
API_CONTENT_TYPE_HEADER=application/json
API_TIMEOUT_MS=60000
API_IGNORE_HTTPS_ERRORS=false
API_LOG_LEVEL=none
API_LOG_PRETTY=true
API_LOG_MAX_BODY_CHARS=1200

# Optional authentication placeholders for secured APIs.
# Prefer API_BEARER_TOKEN when available. Basic auth is used only when both username and password are set.
API_BEARER_TOKEN=
API_USERNAME=
API_PASSWORD=

# Optional deterministic test-data seed. Leave blank for time-based randomized data.
TEST_DATA_SEED=
TEST_PET_ID_MIN=100000000
TEST_PET_ID_MAX=999999999999

