{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pet response",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "photoUrls", "status"],
  "properties": {
    "id": {
      "type": "integer"
    },
    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "photoUrls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["available", "pending", "sold"]
    }
  }
}
